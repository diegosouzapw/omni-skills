---
import '../styles/global.css';
const title = 'Example';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      rel="preload"
      href="/fonts/Inter-roman-subset.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <style is:global>
      @font-face {
        font-family: 'Inter';
        src: url('/fonts/Inter-roman-subset.woff2') format('woff2');
        font-style: normal;
        font-weight: 100 900;
        font-display: swap;
      }

      :root {
        font-family: 'Inter', system-ui, sans-serif;
      }
    </style>

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
