{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CheckoutCompletedEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_time",
    "user_id",
    "order_id",
    "currency",
    "total_amount"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "description": "Stable unique event identifier"
    },
    "event_time": {
      "type": "string",
      "format": "date-time",
      "description": "UTC event timestamp"
    },
    "user_id": {
      "type": "string"
    },
    "order_id": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "enum": ["USD", "EUR", "GBP"]
    },
    "total_amount": {
      "type": "number",
      "minimum": 0
    },
    "coupon_code": {
      "type": ["string", "null"],
      "description": "Null when no coupon was applied"
    }
  }
}
